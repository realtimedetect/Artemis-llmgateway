# ── Database ──────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=llm_gatway
DB_USER=gatway
DB_PASSWORD=gatwaysecret
DB_ROOT_PASSWORD=rootsecret

# ── Backend ───────────────────────────────────────────────
PORT=8080
JWT_SECRET=change_me_to_a_long_random_string_in_production
FRONTEND_ORIGIN=http://localhost:3000
AUTH_RATE_LIMIT_PER_MIN=20
API_RATE_LIMIT_PER_MIN=120
PROVIDER_MAX_RETRIES=2
CIRCUIT_BREAKER_THRESHOLD=3
CIRCUIT_BREAKER_OPEN_SECONDS=60
AUDIT_MAX_BODY_BYTES=65536

# ── Default Admin Seed (for local/demo) ─────────────────
DEFAULT_ADMIN_ENABLED=true
DEFAULT_ADMIN_ID=00000000-0000-0000-0000-000000000001
DEFAULT_ADMIN_EMAIL=admin@llm-gatway.local
# bcrypt hash for password: admin123
DEFAULT_ADMIN_PASSWORD_BCRYPT=$2a$10$9n4l4PjeSi4OXMlcdrzmi.VfSv1ofqdVH9hN6/3rA3Pt0ECNDVJUe

# ── Frontend ──────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080
